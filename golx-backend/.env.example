# ============================================================
# GOLX Backend — Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

NODE_ENV=development
LOG_LEVEL=info
PORT=3000
APP_TIME_ZONE=Africa/Cairo

# PostgreSQL (via pgBouncer in production)
DATABASE_URL=postgresql://golx_user:golx_pass@localhost:5432/golx_dev
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_APPLICATION_NAME=goalix-api
DB_STATEMENT_TIMEOUT_MS=30000
DB_IDLE_IN_TRANSACTION_SESSION_TIMEOUT_MS=10000
DB_LOCK_TIMEOUT_MS=5000

# Redis
REDIS_URL=redis://localhost:6379
AUTH_SESSION_CACHE_TTL_SECONDS=900
AUTH_SESSION_LAST_SEEN_INTERVAL_SECONDS=300
AUTH_SESSION_LAST_SEEN_JITTER_SECONDS=60
AUTH_USER_CACHE_TTL_SECONDS=120
ACADEMY_BRANCHES_CACHE_TTL_SECONDS=120
NOTIFICATION_UNREAD_COUNT_CACHE_TTL_SECONDS=30
CHAT_CONVERSATIONS_CACHE_TTL_SECONDS=15
AUTH_EPHEMERAL_RETENTION_DAYS=30

# HTTP server
HTTP_LISTEN_BACKLOG=8192
HTTP_KEEP_ALIVE_TIMEOUT_MS=65000
HTTP_HEADERS_TIMEOUT_MS=66000
HTTP_REQUEST_TIMEOUT_MS=120000
SLOW_QUERY_LOG_MS=250
SLOW_QUERY_SQL_MAX_CHARS=2000
SLOW_REQUEST_LOG_MS=1000

# JWT
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars-long!!
JWT_REFRESH_SECRET=your-super-secret-refresh-key-at-least-32-chars!!
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# BullMQ
BULLMQ_PREFIX=golx
# Keep this true for convenient local development. In production, set it to
# false on API replicas and run `npm run worker` as a separate service.
BULLMQ_WORKERS_ENABLED=true

# Enable scheduled scans on one designated instance only.
BACKGROUND_AUTOMATIONS_ENABLED=false
INJURY_RISK_AUTOMATION_ENABLED=false

# Python models
# Override this only when `python` is not the executable you want the API to use.
PYTHON_BIN=python
INJURY_RISK_MODEL_TIMEOUT_MS=60000
RANKING_MODEL_TIMEOUT_MS=60000

# CORS
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# Bcrypt
BCRYPT_ROUNDS=12

# Pagination
DEFAULT_PAGE_LIMIT=20
MAX_PAGE_LIMIT=100

# Account Lockout
MAX_FAILED_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
ADMIN_MAX_FAILED_LOGIN_ATTEMPTS=3
ADMIN_LOCKOUT_DURATION_MINUTES=30

# TOTP 2FA
TOTP_ISSUER=GOLX Academy

# Admin Login Rate Limit
ADMIN_AUTH_RATE_LIMIT_MAX=5
ADMIN_AUTH_RATE_LIMIT_WINDOW_MINUTES=15
