{
    "name": "golx-backend",
    "version": "1.0.0",
    "description": "GOLX Sports Academy Platform — Backend API",
    "main": "src/server.js",
    "scripts": {
        "start": "node src/server.js",
        "dev": "nodemon src/server.js",
        "worker": "node src/workers/run.js",
        "migrate": "knex migrate:latest",
        "migrate:rollback": "knex migrate:rollback",
        "migrate:make": "knex migrate:make",
        "seed": "knex seed:run",
        "seed:admin": "knex seed:run --specific=03_bootstrap_admin.js",
        "seed:make": "knex seed:make",
        "fixtures:e2e": "node scripts/create-e2e-fixtures.js",
        "test:e2e:roles": "node scripts/test-e2e-roles.js",
        "test": "jest --runInBand",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix"
    },
    "dependencies": {
        "bcrypt": "^6.0.0",
        "bullmq": "^5.79.1",
        "compression": "^1.7.5",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.21.2",
        "express-rate-limit": "^7.4.1",
        "helmet": "^8.2.0",
        "hpp": "^0.2.3",
        "ioredis": "^5.11.1",
        "jsonwebtoken": "^9.0.2",
        "knex": "^3.2.10",
        "multer": "^2.2.0",
        "otplib": "^13.4.0",
        "pg": "^8.22.0",
        "pino": "^9.5.0",
        "pino-pretty": "^11.3.0",
        "qrcode": "^1.5.4",
        "socket.io": "^4.8.3",
        "uuid": "^11.1.1",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "eslint": "^9.13.0",
        "jest": "^29.7.0",
        "nodemon": "^3.1.7",
        "supertest": "^7.0.0"
    },
    "overrides": {
        "qs": "6.15.2",
        "ws": "8.21.0"
    },
    "engines": {
        "node": ">=20.0.0"
    }
}
